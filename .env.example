# Local dev secrets for docker-compose. Copy to .env (gitignored) and fill in,
# or let ./rebuild.sh auto-generate values on first run.
#
# docker compose reads this file automatically for variable substitution.

# PostgreSQL admin password used by the local `postgres` service and by the
# backend's ConnectionStrings__Postgres. Auto-generated by ./rebuild.sh if
# missing. Override here if you want a specific value.
POSTGRES_PASSWORD=
