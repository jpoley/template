# Copy to terraform.tfvars and fill in. terraform.tfvars is gitignored.

project_name = "projecttemplate"
environment  = "dev"
location     = "eastus2"

# Container images. CI pushes these before `terraform apply`.
backend_image  = "<acr-name>.azurecr.io/projecttemplate/backend:latest"
frontend_image = "<acr-name>.azurecr.io/projecttemplate/frontend:latest"
admin_image    = "<acr-name>.azurecr.io/projecttemplate/admin:latest"

# PostgreSQL (Azure Database for PostgreSQL Flexible Server)
postgres_sku_name            = "B_Standard_B1ms"
postgres_storage_mb          = 32768
postgres_version             = "16"
postgres_administrator_login = "pgadmin"
# Do NOT commit the password. Supply via TF_VAR_postgres_administrator_password
# or a gitignored *.auto.tfvars file.
# postgres_administrator_password = "set-via-env-or-secret-tfvars"

# Backend scale
backend_min_replicas = 1
backend_max_replicas = 5

# Log retention (days)
log_analytics_retention_days = 30

# Front Door
frontdoor_sku = "Standard_AzureFrontDoor"
custom_domain = ""

# Lock down admin UI to your office IPs
admin_allowed_ips = []

tags = {
  owner = "platform-team"
}
